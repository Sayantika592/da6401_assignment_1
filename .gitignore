#################################
# Ignore everything by default
#################################
*

#################################
# Allow src folder and its code
#################################
!src/
!src/**

!models/
!models/**

!notebooks/
!notebooks/**

#################################
# Allow git metadata files
#################################
!.gitignore
!README.md
!requirements.txt

#################################
# Python cache
#################################
__pycache__/
*.pyc
*.pyo
*.pyd

#################################
# Virtual environments
#################################
venv/
.env/
.envrc

#################################
# VSCode / IDE
#################################
.vscode/
.idea/

#################################
# W&B experiment logs
#################################
wandb/

#################################
# Model artifacts (do not track)
#################################
*.npy
*.npz
*.pt
*.pth

#################################
# Config files generated during training
#################################
!best_config.json
!best_model.npy
log_samples.py

#################################
# Dataset caches
#################################
mnist_cache.npz
fashion_mnist_cache.npz

#################################
# Misc
#################################
.DS_Store
Thumbs.db